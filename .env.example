# Copy to .env and fill in values for local development.

# --- Turso (optional — leave commented to use local SQLite) ---
# Create a database: turso db create group-day-planner
# Get URL:        turso db show group-day-planner --url
# Get token:      turso db tokens create group-day-planner
# TURSO_DATABASE_URL=libsql://your-database-name-org.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# Optional: local embedded replica for faster reads (syncs with Turso cloud)
# TURSO_LOCAL_PATH=./turso_replica.db

# --- Local SQLite (default when Turso vars are unset) ---
# DATABASE_PATH=./group_day_planner.db

# Required in production
# SECRET_KEY=generate-a-long-random-string
